{
  "name": "capital-premios-api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "start:aws": "node dist/src/main.js",
    "docker:build": "docker compose build api",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f api",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "prisma:migrate": "dotenv -e .env.development -- prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:generate": "dotenv -e .env.development -- prisma generate",
    "prisma:seed": "dotenv -e .env.development -- ts-node prisma/seed.ts",
    "seed:vendas": "dotenv -e .env.development -- ts-node prisma/seed-vendas.ts",
    "seed:vendas:homolog": "dotenv -e .env.homolog -- ts-node prisma/seed-vendas.ts",
    "seed:vendas:prod": "dotenv -e .env.production -- ts-node prisma/seed-vendas.ts",
    "seed:dashboard": "dotenv -e .env.development -- ts-node prisma/seed-dashboard.ts",
    "prisma:studio": "dotenv -e .env.development -- prisma studio",
    "prisma:reset": "dotenv -e .env.development -- prisma migrate reset --force",
    "pm2:start": "pm2 start ecosystem.config.cjs --env homolog",
    "pm2:reload": "pm2 reload ecosystem.config.cjs --env homolog --update-env",
    "pm2:restart": "pm2 restart capital-premios-api --update-env",
    "pm2:stop": "pm2 stop capital-premios-api",
    "pm2:delete": "pm2 delete capital-premios-api",
    "pm2:logs": "pm2 logs capital-premios-api",
    "pm2:save": "pm2 save",
    "pm2:start:prod": "pm2 start ecosystem.config.cjs --env production",
    "pm2:reload:prod": "pm2 reload ecosystem.config.cjs --env production --update-env",
    "prisma:deploy:homolog": "dotenv -e .env.homolog -- prisma migrate deploy",
    "prisma:deploy:prod": "dotenv -e .env.production -- prisma migrate deploy",
    "prisma:generate:homolog": "dotenv -e .env.homolog -- prisma generate",
    "prisma:generate:prod": "dotenv -e .env.production -- prisma generate",
    "deploy:homolog": "npm install && npm run prisma:deploy:homolog && npm run prisma:generate:homolog && npm run build && npm run pm2:reload",
    "deploy:prod": "npm install && npm run prisma:deploy:prod && npm run prisma:generate:prod && npm run build && npm run pm2:reload:prod",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "@aws-sdk/lib-storage": "^3.1024.0",
    "@bull-board/api": "^7.0.0",
    "@bull-board/express": "^7.0.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.18",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.19.3",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.73.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "compression": "^1.8.1",
    "exceljs": "^4.4.0",
    "firebase-admin": "^13.7.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pdfkit": "^0.17.2",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.18",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.19.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/pdfkit": "^0.17.5",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^6.0.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^16.5.0",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "prisma": "^6.19.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "coverageThreshold": {
      "global": {
        "statements": 70,
        "functions": 70
      }
    }
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts",
    "seed:vendas": "ts-node prisma/seed-vendas.ts",
    "seed:vendas:homolog": "ts-node prisma/seed-vendas.ts",
    "seed:vendas:prod": "ts-node prisma/seed-vendas.ts",
    "seed:dashboard": "ts-node prisma/seed-dashboard.ts"
  },
  "overrides": {
    "minimatch": "^10.2.1",
    "glob": "^11.0.0",
    "rimraf": "^6.0.1",
    "ajv": "^8.17.1",
    "path-to-regexp": "^8.4.1",
    "picomatch": "^4.0.4",
    "lodash": "^4.17.21"
  }
}
