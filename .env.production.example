# ============================================================
# PRODUÇÃO — AWS (EC2 + RDS + S3 + ElastiCache)
# ============================================================
# ATENÇÃO: Nunca commitar este arquivo com valores reais!
# Em produção, configure as variáveis diretamente no sistema
# (export VAR=valor) ou via AWS Systems Manager Parameter Store.
# ============================================================
NODE_ENV=production
HOST=0.0.0.0
PORT=3000
APP_URL=https://api.seudominio.com.br
FRONTEND_LOJA_URL=https://loja.seudominio.com.br
FRONTEND_ADMIN_URL=https://admin.seudominio.com.br

# AWS RDS PostgreSQL
DATABASE_URL=postgresql://usuario:senha@seu-rds-endpoint.rds.amazonaws.com:5432/capital_premios_db?sslmode=require

# Redis — ElastiCache ou Redis em EC2
REDIS_URL=redis://seu-redis-endpoint:6379

# JWT — use segredos longos e aleatórios em produção
JWT_ACCESS_SECRET=MUDE_PARA_UM_SEGREDO_LONGO_E_ALEATORIO_64_CHARS
JWT_REFRESH_SECRET=MUDE_PARA_OUTRO_SEGREDO_LONGO_E_ALEATORIO_64_CHARS
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Gateways de Pagamento (produção)
PAGBANK_API_URL=https://api.pagseguro.com
PAGBANK_TOKEN=token_producao
PAGBANK_NOTIFICATION_URL=https://api.seudominio.com.br/api/pagamentos/webhook/pix
GATEWAY_PIX_URL=https://api.gateway-pix.com
GATEWAY_PIX_TOKEN=token_producao
GATEWAY_PIX_WEBHOOK_SECRET=secret_producao
MOCK_PIX_AUTO_APPROVE=false

GATEWAY_CARTAO_URL=https://api.gateway-cartao.com
GATEWAY_CARTAO_TOKEN=token_producao
GATEWAY_CARTAO_WEBHOOK_SECRET=secret_producao

# AWS S3
# Em EC2 com IAM Role, ACCESS_KEY_ID e SECRET não são necessários
# (o SDK usa as credenciais da Role automaticamente via metadata service)
# Preencha apenas se não usar IAM Role:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=sa-east-1
AWS_BUCKET_NAME=capital-premios-uploads-prod
AWS_S3_USE_ACL=false
AWS_S3_OBJECT_ACL=public-read
AWS_S3_PUBLIC_BASE_URL=

# Swagger — protegido por Basic Auth em produção
SWAGGER_USER=admin
SWAGGER_PASS=MUDE_PARA_SENHA_FORTE
BULL_BOARD_USER=admin
BULL_BOARD_PASS=MUDE_PARA_SENHA_FORTE_FILAS

# Throttle
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Edições - auto encerramento de vendas
EDICOES_AUTO_ENCERRAMENTO_ENABLED=true
EDICOES_AUTO_ENCERRAMENTO_INTERVAL_MS=30000
EDICOES_AUTO_ENCERRAMENTO_BATCH_SIZE=20
