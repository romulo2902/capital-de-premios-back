# ============================================================
# HOMOLOGAÇÃO — AWS (EC2 + RDS + S3 + ElastiCache)
# ============================================================
# ATENÇÃO: Nunca commitar este arquivo com valores reais!
# Em homologação, configure as variáveis diretamente no sistema
# (export VAR=valor) ou carregue este arquivo antes de iniciar o PM2.
# ============================================================
NODE_ENV=homolog
HOST=0.0.0.0
PORT=3000
REQUEST_BODY_LIMIT=50mb
APP_URL=https://api2.capitaldepremios.com.br
FRONTEND_LOJA_URL=https://vendas.capitaldepremios.com.br
URL_LOJA_CLIENTE=https://vendas.capitaldepremios.com.br
FRONTEND_ADMIN_URL=https://admincdp.capitaldepremios.com.br

# AWS RDS PostgreSQL
DATABASE_URL=postgresql://usuario:senha@seu-rds-endpoint.rds.amazonaws.com:5432/capital_premios_homolog?sslmode=require

# Redis — ElastiCache ou Redis em EC2
REDIS_URL=redis://seu-redis-endpoint:6379

# JWT — use segredos próprios de homologação
JWT_ACCESS_SECRET=HOMOLOG_ACCESS_SECRET
JWT_REFRESH_SECRET=HOMOLOG_REFRESH_SECRET
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Gateways de Pagamento (sandbox/homolog)
PAGBANK_API_URL=https://sandbox.api.pagseguro.com
PAGBANK_TOKEN=token_homolog
PAGBANK_NOTIFICATION_URL=https://api2.capitaldepremios.com.br/api/pagamentos/webhook/pix
GATEWAY_PIX_URL=https://sandbox.gateway-pix.com
GATEWAY_PIX_TOKEN=token_homolog
GATEWAY_PIX_WEBHOOK_SECRET=secret_homolog
MOCK_PIX_AUTO_APPROVE=false

GATEWAY_CARTAO_URL=https://sandbox.gateway-cartao.com
GATEWAY_CARTAO_TOKEN=token_homolog
GATEWAY_CARTAO_WEBHOOK_SECRET=secret_homolog

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=sa-east-1
AWS_BUCKET_NAME=capital-premios-uploads-homolog
AWS_S3_USE_ACL=false
AWS_S3_OBJECT_ACL=public-read
AWS_S3_PUBLIC_BASE_URL=

# Swagger
SWAGGER_USER=admin
SWAGGER_PASS=homolog_forte
BULL_BOARD_USER=admin
BULL_BOARD_PASS=homolog_forte_filas

# Throttle
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Edições - auto encerramento de vendas
EDICOES_AUTO_ENCERRAMENTO_ENABLED=true
EDICOES_AUTO_ENCERRAMENTO_INTERVAL_MS=30000
EDICOES_AUTO_ENCERRAMENTO_BATCH_SIZE=20

# Docker (opcional)
DOCKER_DATABASE_HOST=
DOCKER_REDIS_HOST=
FIREBASE_MOUNT_HOST_DIR=/home/ubuntu/homologacao/backend/firebase
FIREBASE_MOUNT_CONTAINER_DIR=/home/ubuntu/homologacao/backend/firebase
POSTGRES_USER=capital_user
POSTGRES_PASSWORD=capital@123
POSTGRES_DB=capital_premios_homolog
POSTGRES_HOST_PORT=55432
REDIS_HOST_PORT=56379
