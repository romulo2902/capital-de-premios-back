// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Perfil {
  ADMIN
  DISTRIBUIDOR
  VENDEDOR
  CLIENTE
}

enum StatusUsuario {
  ATIVO
  INATIVO
}

enum StatusEdicao {
  RASCUNHO
  ATIVA
  ENCERRADA
  SORTEANDO
  FINALIZADA
}

enum StatusVenda {
  PENDENTE
  APROVADO
  RECUSADO
  CANCELADO
}

enum TipoPagamento {
  PIX
  CARTAO
  MANUAL
}

enum StatusSaque {
  SOLICITADO
  APROVADO
  PAGO
  RECUSADO
}

enum TipoSaque {
  VENDEDOR
  DISTRIBUIDOR
}

enum StatusComissao {
  PENDENTE
  PAGO
}

enum TipoChavePix {
  CPF
  CNPJ
  EMAIL
  TELEFONE
  ALEATORIA
}

enum DestinoEdicao {
  SITE
  LOJA_FISICA
  AMBOS
}

enum OrigemParticipacao {
  DIGITAL
  FISICO
  POS
}

enum TipoCartela {
  UMA_CHANCE
  DUAS_CHANCES
  TRES_CHANCES
  QUATRO_CHANCES
  CINCO_CHANCES
  SEIS_CHANCES
  SETE_CHANCES
  OITO_CHANCES
  NOVE_CHANCES
  DEZ_CHANCES
  ONZE_CHANCES
  DOZE_CHANCES
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  UPSERT
  CREATE_MANY
  UPDATE_MANY
  DELETE_MANY
}

// ─── Capital Sena Enums ──────────────────────────────────

enum StatusEdicaoSena {
  RASCUNHO
  ATIVA
  ENCERRADA
  APURANDO
  FINALIZADA
}

enum StatusCartelaSena {
  PENDENTE_PAGAMENTO
  CONFIRMADA
  NAO_PREMIADA
  QUADRA
  QUINA
  SENA
  SENA_BONUS
}

enum StatusVendaSena {
  PENDENTE
  APROVADO
  RECUSADO
  CANCELADO
}

enum ModoSelecaoSena {
  MANUAL
  SURPRESINHA
}

enum FaixaPremiacao {
  QUADRA
  QUINA
  SENA
  SENA_BONUS
}

model Usuario {
  id                 String        @id @default(uuid())
  cpf                String?       @unique
  email              String?       @unique
  senhaHash          String?
  perfil             Perfil
  deveRedefinirSenha Boolean       @default(false)
  status             StatusUsuario @default(ATIVO)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model Distribuidor {
  id                        String                     @id @default(uuid())
  codigo                    Int                        @unique @default(autoincrement())
  usuarioId                 String                     @unique
  nome                      String
  cpf                       String                     @unique
  telefone                  String
  dataNascimento            DateTime?
  cep                       String?
  endereco                  String?
  numero                    String?
  bairro                    String?
  cidade                    String?
  estado                    String?
  email                     String
  tipoChavePix              TipoChavePix?
  chavePix                  String?
  comissaoPercent           Decimal                    @default(0)
  saldo                     Decimal                    @default(0)
  link                      String?
  qrcode                    String?
  status                    StatusUsuario              @default(ATIVO)
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  vendedores                Vendedor[]
  clientes                  Cliente[]
  saques                    Saque[]
  comissoesDistribuidor     ComissaoDistribuidor[]
  comissoesDistribuidorSena ComissaoDistribuidorSena[]
}

model Vendedor {
  id              String         @id @default(uuid())
  codigo          Int            @unique @default(autoincrement())
  usuarioId       String         @unique
  distribuidorId  String
  nome            String
  cpf             String         @unique
  nomeRecebedor   String?
  comissaoPercent Decimal        @default(0)
  telefone        String
  dataNascimento  DateTime?
  cep             String?
  endereco        String?
  numero          String?
  bairro          String?
  cidade          String?
  estado          String?
  email           String
  tipoChavePix    TipoChavePix?
  chavePix        String?
  saldo           Decimal        @default(0)
  link            String?
  qrcode          String?
  status          StatusUsuario  @default(ATIVO)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  distribuidor    Distribuidor   @relation(fields: [distribuidorId], references: [id])
  clientes        Cliente[]
  vendas          Venda[]
  vendasSena      VendaSena[]
  comissoes       Comissao[]
  comissoesSena   ComissaoSena[]
  saques          Saque[]
}

model Cliente {
  id             String        @id @default(uuid())
  codigo         Int           @unique @default(autoincrement())
  cpf            String        @unique
  nome           String
  telefone       String
  dataNascimento DateTime?
  cep            String?
  endereco       String?
  numero         String?
  bairro         String?
  cidade         String?
  estado         String?
  email          String?
  vendedorId     String?
  distribuidorId String?
  status         StatusUsuario @default(ATIVO)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  vendedor       Vendedor?     @relation(fields: [vendedorId], references: [id])
  distribuidor   Distribuidor? @relation(fields: [distribuidorId], references: [id])
  vendas         Venda[]
  vendasSena     VendaSena[]
}

model Edicao {
  id                 String            @id @default(uuid())
  numero             String
  dataSorteio        DateTime
  dataEncerramento   DateTime
  valorCartela       Decimal
  qtdNumerosCartela  Int
  rangeInicio        BigInt
  rangeFinal         BigInt
  qtdPremios         Int
  destino            DestinoEdicao     @default(SITE)
  raspadinha         Boolean           @default(false)
  frase              String?
  especie            String?
  imagemUrl          String?
  manutencaoAtiva    Boolean           @default(false)
  manutencaoMensagem String?
  status             StatusEdicao      @default(RASCUNHO)
  createdAt          DateTime          @default(now())
  premios            Premio[]
  detalhes           EdicaoDetalhe[]
  combos             EdicaoCombo[]
  vendas             Venda[]
  resultado          Resultado?
  resultadosPremio   ResultadoPremio[]
}

model EdicaoDetalhe {
  id                 String             @id @default(uuid())
  edicaoId           String
  origemParticipacao OrigemParticipacao
  tipoCartela        TipoCartela
  indiceRange        Int
  rangeInicio        BigInt
  rangeFinal         BigInt
  preco              Decimal?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  edicao             Edicao             @relation(fields: [edicaoId], references: [id], onDelete: Cascade)

  @@unique([edicaoId, origemParticipacao, indiceRange])
  @@index([edicaoId])
}

model EdicaoCombo {
  id                 String             @id @default(uuid())
  edicaoId           String
  origemParticipacao OrigemParticipacao
  tipoCartela        TipoCartela
  preco              Decimal
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  edicao             Edicao             @relation(fields: [edicaoId], references: [id], onDelete: Cascade)

  @@unique([edicaoId, origemParticipacao, tipoCartela])
  @@index([edicaoId])
}

model Premio {
  id                String           @id @default(uuid())
  edicaoId          String
  ordem             Int
  descricao         String
  valor             Decimal
  imagemUrl         String?
  ganhadorBilheteId String?
  edicao            Edicao           @relation(fields: [edicaoId], references: [id])
  resultadoPremio   ResultadoPremio?
}

model MatrizRange {
  id             String    @id @default(uuid())
  numero         BigInt    @unique
  sequenciaBolas Int[]
  bilhetes       Bilhete[]
}

model Venda {
  id                   String                @id @default(uuid())
  edicaoId             String
  clienteId            String
  vendedorId           String?
  distribuidorId       String?
  quantidade           Int
  tipoCartela          TipoCartela?
  total                Decimal
  status               StatusVenda           @default(PENDENTE)
  origemParticipacao   OrigemParticipacao    @default(DIGITAL)
  tipoPagamento        TipoPagamento
  gatewayId            String?
  gatewayPayload       Json?
  createdAt            DateTime              @default(now())
  edicao               Edicao                @relation(fields: [edicaoId], references: [id])
  cliente              Cliente               @relation(fields: [clienteId], references: [id])
  vendedor             Vendedor?             @relation(fields: [vendedorId], references: [id])
  bilhetes             Bilhete[]
  comissao             Comissao?
  comissaoDistribuidor ComissaoDistribuidor?
}

model Bilhete {
  id             String      @id @default(uuid())
  vendaId        String
  edicaoId       String
  matrizId       String
  numero         BigInt
  sequenciaBolas Int[]
  ganhador       Boolean     @default(false)
  premioId       String?
  venda          Venda       @relation(fields: [vendaId], references: [id])
  matriz         MatrizRange @relation(fields: [matrizId], references: [id])

  @@unique([matrizId, edicaoId])
  @@index([edicaoId])
}

model Resultado {
  id              String   @id @default(uuid())
  edicaoId        String   @unique
  numerosApurados Int[]
  createdAt       DateTime @default(now())
  edicao          Edicao   @relation(fields: [edicaoId], references: [id])
}

model ResultadoPremio {
  id                String   @id @default(uuid())
  premioId          String   @unique
  edicaoId          String
  numerosMarcados   Int[]
  ganhadorBilheteId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  premio            Premio   @relation(fields: [premioId], references: [id])
  edicao            Edicao   @relation(fields: [edicaoId], references: [id])

  @@index([edicaoId])
}

model Comissao {
  id         String         @id @default(uuid())
  vendedorId String
  vendaId    String         @unique
  valor      Decimal
  status     StatusComissao @default(PENDENTE)
  createdAt  DateTime       @default(now())
  vendedor   Vendedor       @relation(fields: [vendedorId], references: [id])
  venda      Venda          @relation(fields: [vendaId], references: [id])
}

model ComissaoDistribuidor {
  id             String         @id @default(uuid())
  distribuidorId String
  vendaId        String         @unique
  valor          Decimal
  status         StatusComissao @default(PENDENTE)
  createdAt      DateTime       @default(now())
  distribuidor   Distribuidor   @relation(fields: [distribuidorId], references: [id])
  venda          Venda          @relation(fields: [vendaId], references: [id])
}

model Saque {
  id             String        @id @default(uuid())
  tipo           TipoSaque
  vendedorId     String?
  distribuidorId String?
  valor          Decimal
  status         StatusSaque   @default(SOLICITADO)
  createdAt      DateTime      @default(now())
  vendedor       Vendedor?     @relation(fields: [vendedorId], references: [id])
  distribuidor   Distribuidor? @relation(fields: [distribuidorId], references: [id])
}

model PaginaConteudo {
  id        String   @id @default(uuid())
  slug      String   @unique
  titulo    String
  conteudo  String
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContatoMensagem {
  id          String   @id @default(uuid())
  nome        String
  cpf         String
  email       String
  telefone    String
  mensagem    String
  fingerprint String
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([cpf, createdAt])
  @@index([fingerprint, createdAt])
}

model AuditLog {
  id          String      @id @default(uuid())
  requestId   String?
  method      String?
  path        String?
  ip          String?
  userAgent   String?
  actorId     String?
  actorPerfil String?
  actorEmail  String?
  model       String
  action      AuditAction
  entityId    String?
  oldData     Json?
  newData     Json?
  metadata    Json?
  createdAt   DateTime    @default(now())

  @@index([createdAt])
  @@index([model, createdAt])
  @@index([actorId, createdAt])
  @@index([requestId])
}

// ─── Capital Sena Models ─────────────────────────────────

model EdicaoSena {
  id                  String           @id @default(uuid())
  numero              String           @unique
  descricao           String?
  dataSorteioMegaSena DateTime
  dataEncerramento    DateTime
  valorCartela        Decimal
  imagemUrl           String?
  status              StatusEdicaoSena @default(RASCUNHO)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  premios   PremioSena[]
  combos    ComboSena[]
  vendas    VendaSena[]
  resultado ResultadoSena?
  cartelas  CartelaSena[]

  @@index([status])
}

model ComboSena {
  id           String   @id @default(uuid())
  edicaoSenaId String
  nome         String
  quantidade   Int
  preco        Decimal
  ativo        Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  edicaoSena EdicaoSena @relation(fields: [edicaoSenaId], references: [id], onDelete: Cascade)

  @@index([edicaoSenaId])
}

model PremioSena {
  id           String         @id @default(uuid())
  edicaoSenaId String
  faixa        FaixaPremiacao
  descricao    String
  valor        Decimal
  imagemUrl    String?

  edicaoSena EdicaoSena @relation(fields: [edicaoSenaId], references: [id], onDelete: Cascade)

  @@unique([edicaoSenaId, faixa])
  @@index([edicaoSenaId])
}

model VendaSena {
  id             String          @id @default(uuid())
  edicaoSenaId   String
  clienteId      String
  vendedorId     String?
  distribuidorId String?
  comboSenaId    String?
  quantidade     Int
  total          Decimal
  status         StatusVendaSena @default(PENDENTE)
  tipoPagamento  TipoPagamento
  origemParticipacao OrigemParticipacao @default(DIGITAL)
  gatewayId      String?
  gatewayPayload Json?
  createdAt      DateTime        @default(now())

  edicaoSena               EdicaoSena                @relation(fields: [edicaoSenaId], references: [id])
  cliente                  Cliente                   @relation(fields: [clienteId], references: [id])
  vendedor                 Vendedor?                 @relation(fields: [vendedorId], references: [id])
  cartelas                 CartelaSena[]
  comissaoSena             ComissaoSena?
  comissaoDistribuidorSena ComissaoDistribuidorSena?

  @@index([edicaoSenaId])
  @@index([clienteId])
}

model CartelaSena {
  id                String            @id @default(uuid())
  vendaSenaId       String
  edicaoSenaId      String
  numerosEscolhidos Int[]
  setimoNumero      Int?
  modoSelecao       ModoSelecaoSena
  acertos           Int?
  setimoAcertou     Boolean?
  status            StatusCartelaSena @default(PENDENTE_PAGAMENTO)
  createdAt         DateTime          @default(now())

  vendaSena  VendaSena  @relation(fields: [vendaSenaId], references: [id])
  edicaoSena EdicaoSena @relation(fields: [edicaoSenaId], references: [id])

  @@index([edicaoSenaId])
  @@index([vendaSenaId])
  @@index([status])
}

model ResultadoSena {
  id                 String    @id @default(uuid())
  edicaoSenaId       String    @unique
  numerosSorteados   Int[]
  imagemResultadoUrl String?
  apurado            Boolean   @default(false)
  apuradoEm          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  edicaoSena EdicaoSena @relation(fields: [edicaoSenaId], references: [id])
}

model ComissaoSena {
  id          String         @id @default(uuid())
  vendedorId  String
  vendaSenaId String         @unique
  valor       Decimal
  status      StatusComissao @default(PENDENTE)
  createdAt   DateTime       @default(now())

  vendedor  Vendedor  @relation(fields: [vendedorId], references: [id])
  vendaSena VendaSena @relation(fields: [vendaSenaId], references: [id])
}

model ComissaoDistribuidorSena {
  id             String         @id @default(uuid())
  distribuidorId String
  vendaSenaId    String         @unique
  valor          Decimal
  status         StatusComissao @default(PENDENTE)
  createdAt      DateTime       @default(now())

  distribuidor Distribuidor @relation(fields: [distribuidorId], references: [id])
  vendaSena    VendaSena    @relation(fields: [vendaSenaId], references: [id])
}

/// Configuração global de percentuais de comissão padrão.
/// Tabela singleton — apenas uma linha com chave = "DEFAULT".
model ConfiguracaoComissao {
  chave                    String  @id @default("DEFAULT")
  percentualDistribuidor   Decimal @default(0)
  percentualVendedor       Decimal @default(0)
  updatedAt                DateTime @updatedAt
}
