# App
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
REQUEST_BODY_LIMIT=50mb
APP_URL=http://localhost:3000
FRONTEND_LOJA_URL=http://localhost:3001
URL_LOJA_CLIENTE=http://localhost:3001
FRONTEND_ADMIN_URL=http://localhost:3002
# Opcional: lista separada por virgula para liberar multiplas origens no CORS
# Ex.: http://52.2.52.106:3002,http://52.2.52.106:3001
FRONTEND_ALLOWED_ORIGINS=

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/capital_premios_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=sua_chave_access_aqui
JWT_REFRESH_SECRET=sua_chave_refresh_aqui
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
# POS — sessão longa do terminal (login por CPF). Secret isolado do painel admin.
JWT_POS_SECRET=sua_chave_pos_aqui
JWT_POS_EXPIRES=180d

# PagBank — Gateway de Pagamento (PIX + Cartão de Crédito)
# Sandbox: https://sandbox.api.pagseguro.com
# Produção: https://api.pagseguro.com
# Credenciais em: https://minha.conta.pagseguro.uol.com.br/preferencias/credenciais
# Mock aprovação de pagamento (em dev, tudo é aprovado)
MOCK_PIX_AUTO_APPROVE=true
PAGBANK_API_URL=https://sandbox.api.pagseguro.com
PAGBANK_CLIENT_ID=seu_client_id_aqui
PAGBANK_CLIENT_SECRET=seu_client_secret_aqui
PAGBANK_PIX_KEY=sua_chave_pix_aqui
# Opcional: se vazio, usa ${APP_URL}/api/pagamentos/webhook/pix
PAGBANK_NOTIFICATION_URL=
# PAGBANK_WEBHOOK_SECRET configurado no painel PagBank (Notificações)
PAGBANK_WEBHOOK_SECRET=seu_webhook_secret_aqui

# Provedor de PIX ativo: PAGBANK | MERCADOPAGO (default: PAGBANK)
PIX_GATEWAY_PROVIDER=PAGBANK

# Mercado Pago — Gateway de Pagamento alternativo (PIX via Orders API)
# Sandbox e produção usam a mesma URL — o ambiente é definido pelo Access Token (TEST- ou APP_USR-)
# Credenciais em: https://www.mercadopago.com.br/developers/panel/app
MERCADOPAGO_API_URL=https://api.mercadopago.com
MERCADOPAGO_ACCESS_TOKEN=seu_access_token_aqui
# MERCADOPAGO_WEBHOOK_SECRET configurado no painel Mercado Pago (Webhooks > Configurar notificações)
MERCADOPAGO_WEBHOOK_SECRET=seu_webhook_secret_aqui
WHATSAPP_CONFIRMACAO_PAGAMENTO_URL=https://n8n-capital.vectrosolutions.com/webhook/confirmacao-capital

# AWS S3
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=sa-east-1
AWS_BUCKET_NAME=capital-premios-uploads
AWS_S3_USE_ACL=false
AWS_S3_OBJECT_ACL=public-read
AWS_S3_PUBLIC_BASE_URL=

# Swagger (produção)
SWAGGER_USER=admin
SWAGGER_PASS=senha_swagger_aqui
BULL_BOARD_USER=admin
BULL_BOARD_PASS=senha_filas_aqui

# Throttle
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Edições - auto encerramento de vendas
EDICOES_AUTO_ENCERRAMENTO_ENABLED=true
EDICOES_AUTO_ENCERRAMENTO_INTERVAL_MS=30000
EDICOES_AUTO_ENCERRAMENTO_BATCH_SIZE=20

# Firebase (Sorteio em tempo real)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Docker (opcional)
# Se DOCKER_DATABASE_HOST/DOCKER_REDIS_HOST forem definidos, o entrypoint
# reescreve localhost/127.0.0.1 das URLs para esses hosts.
DOCKER_DATABASE_HOST=
DOCKER_REDIS_HOST=

# Mount para o Firebase quando rodar via Docker:
FIREBASE_MOUNT_HOST_DIR=../firebase
FIREBASE_MOUNT_CONTAINER_DIR=/home/jair/projetos/freela/capital-premios/firebase

# Infra opcional via Docker profile "infra"
POSTGRES_USER=capital_user
POSTGRES_PASSWORD=capital@123
POSTGRES_DB=capital_premios_db
POSTGRES_HOST_PORT=55432
REDIS_HOST_PORT=56379
